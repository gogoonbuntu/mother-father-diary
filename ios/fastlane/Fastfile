default_platform(:ios)

platform :ios do
  desc "자동 빌드 넘버 증가"
  private_lane :increment_version do
    # pubspec.yaml에서 현재 버전 읽기
    pubspec = File.read("../../pubspec.yaml")
    current_version = pubspec.match(/version:\s*(\d+\.\d+\.\d+)\+(\d+)/i)

    if current_version
      version_name = current_version[1]
      version_code = current_version[2].to_i + 1

      new_pubspec = pubspec.sub(
        /version:\s*\d+\.\d+\.\d+\+\d+/,
        "version: #{version_name}+#{version_code}"
      )
      File.write("../../pubspec.yaml", new_pubspec)
      UI.success("✅ Version updated: #{version_name}+#{version_code}")
    end
  end

  desc "🧪 TestFlight에 업로드"
  lane :beta do
    increment_version

    # Flutter IPA 빌드
    sh("cd ../.. && flutter build ipa --release --export-options-plist=ios/ExportOptions.plist")

    # TestFlight 업로드
    upload_to_testflight(
      ipa: "../../build/ios/ipa/diary_app.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )

    UI.success("🎉 TestFlight 업로드 완료!")
  end

  desc "🚀 App Store 배포"
  lane :deploy do
    increment_version

    sh("cd ../.. && flutter build ipa --release --export-options-plist=ios/ExportOptions.plist")

    upload_to_app_store(
      ipa: "../../build/ios/ipa/diary_app.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      force: true,
      submit_for_review: false,
    )

    UI.success("🚀 App Store 업로드 완료!")
  end

  desc "📸 메타데이터 업로드"
  lane :metadata do
    upload_to_app_store(
      skip_binary_upload: true,
      force: true,
    )
  end
end
